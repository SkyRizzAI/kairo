# https://editorconfig.org — consistent whitespace across editors.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# C/C++ firmware sources
[*.{c,cpp,h,hpp,inc}]
indent_size = 4

# Web / tooling
[*.{ts,tsx,js,jsx,json,css,html}]
indent_size = 2

[*.{yml,yaml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.{cmake,txt}]
indent_size = 4
