# SkyRizz E32 — default sdkconfig overrides
# These are applied on first build (or after deleting sdkconfig).
# Change these to override defaults without editing sdkconfig directly.

# ── Arduino-ESP32 requirements ────────────────────────────────────────────────
CONFIG_FREERTOS_HZ=1000
# arduino-esp32 provides app_main() which calls setup()/loop().
CONFIG_AUTOSTART_ARDUINO=y

# ── C++ features required by core ─────────────────────────────────────────────
# service_container.h uses typeid (RTTI); service_manager.cpp catches std::exception.
CONFIG_COMPILER_CXX_RTTI=y
CONFIG_COMPILER_CXX_EXCEPTIONS=y

# ── Arduino loop task ─────────────────────────────────────────────────────────
# Default is 8192 bytes; setup() initialises LCD, touch, camera, audio, KLP stack
# and can exhaust that easily. 16384 bytes gives comfortable headroom.
CONFIG_ARDUINO_LOOP_STACK_SIZE=16384

# ── Flash / partition table (ESP32-S3-WROOM-1-N16R8: 16 MB flash) ─────────────
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="16MB"
# Use partitions.csv (A/B OTA, 5 MB slots). Binary is ~2.1 MB.
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"

# ── PSRAM (ESP32-S3-WROOM-1-N16R8: 8 MB Octal PSRAM) ─────────────────────────
# Without this, malloc/new only sees ~290 KB DRAM; WiFi+BLE exhaust it before
# the UI arena can allocate, causing std::bad_alloc → boot loop.
CONFIG_SPIRAM=y
CONFIG_SPIRAM_MODE_OCT=y
CONFIG_SPIRAM_SPEED_80M=y
CONFIG_SPIRAM_USE_MALLOC=y
# Allocs ≤ 4 KB stay in fast DRAM; larger allocs (frame buffers, arenas) go to PSRAM.
CONFIG_SPIRAM_MALLOC_ALWAYSINTERNAL=4096
# NOTE: we deliberately do NOT enable SPIRAM_TRY_ALLOCATE_WIFI_LWIP. IDF Kconfig
# makes it mutually exclusive with ESP_WIFI_DYNAMIC_TX_BUFFER (a dynamic TX buffer
# could land in non-DMA PSRAM): turning it on FORCES 16 static TX buffers permanently
# into internal RAM (~26 KB). The dynamic-TX profile (below) frees far more internal
# RAM than try-allocate saved, and it's the profile Flipper-ESP32 ships. See the WiFi
# internal-RAM diet section.
# CONFIG_SPIRAM_TRY_ALLOCATE_WIFI_LWIP is not set
# Internal DMA reserve stays at the 32 KB default. (Raising it to 64 KB starved
# WiFi/mDNS/httpd of internal RAM — they failed to allocate. The SD write NO_MEM is
# better solved by a small persistent bounce buffer than by over-reserving.)
CONFIG_SPIRAM_MALLOC_RESERVE_INTERNAL=32768

# ── Main task stack (global C++ constructors run here) ────────────────────────
# Default 3584 bytes is too small for the HID preloader which calls
# esp_hid_parse_report_map() before app_main(). 8 KB gives comfortable headroom.
CONFIG_ESP_MAIN_TASK_STACK_SIZE=8192

# ── Bluetooth LE (NimBLE) — Plan 73/75 ───────────────────────────────────────
# Without CONFIG_BT_ENABLED the esp32_ble driver compiles as no-op stubs, so the
# Bluetooth settings + BLE remote (Forge web over BLE) do nothing. NimBLE is the
# lightweight BLE-only host (ESP32-S3 has no Classic radio).
CONFIG_BT_ENABLED=y
CONFIG_BT_NIMBLE_ENABLED=y
CONFIG_BT_CONTROLLER_ENABLED=y
# ── WiFi + BLE software coexistence ───────────────────────────────────────────
# ESP32-S3 has ONE 2.4 GHz radio shared by WiFi and BLE. Without SW coexistence,
# running both (WiFi scan/connect WHILE BLE advertises) starves each other. This
# is the prerequisite for the "WiFi + BLE at the same time" goal.
CONFIG_ESP_COEX_SW_COEXIST_ENABLE=y

# ── WiFi internal-RAM diet (Plan 88 — mirrors Flipper-ESP32, but goes further) ──
# Internal SRAM (~230 KB, the ONLY DMA-capable RAM) is shared by WiFi, SD-DMA, I2S,
# LCD, mDNS, httpd. WiFi's STATIC buffers (TX 16×1600 + RX 16×1600 + a 16-deep block-
# ack window) consumed ~55 KB internal, leaving only ~9 KB free → the SD DMA bounce,
# the mDNS task, and the httpd/WS server all failed to allocate (`not enough mem`,
# `wifi:m f null`). Fix: move WiFi TX buffers to DYNAMIC (PSRAM-backed, allocated on
# demand instead of 16 permanent internal ones), trim static RX 16→10, shrink the BA
# window 16→6. Frees ~35-40 KB internal. (Dynamic TX requires TRY_ALLOCATE_WIFI_LWIP
# OFF — see the note above.) Throughput dips slightly; irrelevant for remote+files.
# TX buffer is a Kconfig CHOICE — select the dynamic option (Kconfig then derives
# TX_BUFFER_TYPE=1 and clears STATIC_TX_BUFFER). Setting TX_BUFFER_TYPE directly is
# ignored (it's a derived symbol).
CONFIG_ESP_WIFI_DYNAMIC_TX_BUFFER=y
CONFIG_ESP_WIFI_DYNAMIC_TX_BUFFER_NUM=32
CONFIG_ESP_WIFI_STATIC_RX_BUFFER_NUM=10
CONFIG_ESP_WIFI_RX_BA_WIN=6

# ── HTTP server WebSocket (PLP over WiFi — Plan 75) ──────────────────────────
# Esp32WsTransport runs an esp_http_server WebSocket endpoint at /plp so Forge
# web (browser) can remote the device over WiFi. Without this the WS handler
# (is_websocket / httpd_ws_*) is compiled out.
CONFIG_HTTPD_WS_SUPPORT=y

# ── FATFS for microSD (TF1 on SPI3) ───────────────────────────────────────────
# Long filenames (cards rarely use 8.3) + 512-byte sectors (standard for SD;
# the default 4096 was for flash wear-levelling, which we don't use — internal
# FS is LittleFS). Without LFN, ExFAT also can't mount and long names truncate.
CONFIG_FATFS_LFN_HEAP=y
CONFIG_FATFS_MAX_LFN=255
CONFIG_FATFS_SECTOR_512=y
# FATFS work buffers stay in PSRAM (this board's internal RAM is tight — WiFi+BLE+
# camera+audio). Moving them internal exhausted it and broke f_open. Instead, the
# SD backend uses a persistent internal DMA bounce buffer for the PSRAM→SD copy, so
# writes never do per-call DMA allocations that fail under fragmentation (Plan 88,
# mirrors Flipper-ESP32). See sd_fat_filesystem.cpp.
CONFIG_FATFS_ALLOC_PREFER_EXTRAM=y
