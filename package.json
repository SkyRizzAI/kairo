{
  "name": "palanu",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "cmake -S firmware -B firmware/build -G \"Unix Makefiles\" && cmake --build firmware/build -j && ctest --test-dir firmware/build --output-on-failure",
    "forge": "cd packages/forge && bun run dev",
    "forge:build": "cd packages/forge && bun run build",
    "build:wasm": "bash firmware/tools/build-wasm.sh",
    "forge:wasm": "source ~/emsdk/emsdk_env.sh && bun run build:wasm && bun run forge",
    "build:dev-board": "bash firmware/tools/build-dev-board.sh",
    "flash:dev-board": "bash firmware/tools/flash-dev-board.sh",
    "build:skyrizz-e32": "bash firmware/tools/build-skyrizz-e32.sh",
    "flash:skyrizz-e32": "bash firmware/tools/flash-skyrizz-e32.sh",
    "build:camtest": "bash firmware/tools/build-skyrizz-camtest.sh",
    "flash:camtest": "bash firmware/tools/flash-skyrizz-camtest.sh",
    "build:audiotest": "bash firmware/tools/build-skyrizz-audiotest.sh",
    "flash:audiotest": "bash firmware/tools/flash-skyrizz-audiotest.sh",
    "build:esp32": "bun run build:dev-board",
    "flash:esp32": "bun run flash:dev-board"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
