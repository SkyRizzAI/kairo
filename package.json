{
  "name": "palanu",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "test": "cmake -S firmware -B firmware/build -G \"Unix Makefiles\" && cmake --build firmware/build -j && ctest --test-dir firmware/build --output-on-failure",
    "forge": "cd packages/forge && bun run dev",
    "forge:build": "cd packages/forge && bun run build",
    "build:wasm": "bash firmware/tools/build-wasm.sh",
    "forge:wasm": "source ~/emsdk/emsdk_env.sh && bun run build:wasm && bun run forge",
    "build:dev-board": "bash firmware/tools/build-dev-board.sh",
    "flash:dev-board": "bash firmware/tools/flash-dev-board.sh",
    "build:skyrizz-e32": "bash firmware/tools/build-skyrizz-e32.sh",
    "flash:skyrizz-e32": "bash firmware/tools/flash-skyrizz-e32.sh",
    "build:camtest": "bash firmware/tools/build-skyrizz-camtest.sh",
    "flash:camtest": "bash firmware/tools/flash-skyrizz-camtest.sh",
    "build:audiotest": "bash firmware/tools/build-skyrizz-audiotest.sh",
    "flash:audiotest": "bash firmware/tools/flash-skyrizz-audiotest.sh",
    "build:esp32": "bun run build:dev-board",
    "flash:esp32": "bun run flash:dev-board",
    "dev:ota": "bash firmware/tools/build-dev-ota.sh",
    "idl:parse": "bun run packages/idl/src/parser.ts",
    "idl:gen": "bun run packages/idl/src/gen.ts --ast api/build/nema-api.json --out .",
    "idl:gen:check": "bun run packages/idl/src/gen.ts --ast api/build/nema-api.json --out . --check",
    "idl:test": "cd packages/idl && bun test",
    "app:build": "bun run packages/app-sdk/bin/build.ts",
    "app:build:counter": "bun run packages/app-sdk/bin/build.ts --dir examples/counter",
    "app:build:sysinfo": "bun run packages/app-sdk/bin/build.ts --dir examples/sysinfo",
    "app:build:counter-wasm": "bun run packages/app-sdk/bin/build.ts --dir examples/counter-wasm",
    "app:build:canvas-demo-wasm": "bun run packages/app-sdk/bin/build.ts --dir examples/canvas-demo-wasm",
    "app:build:wifi-marauder": "bun run packages/app-sdk/bin/build.ts --dir examples/wifi-marauder",
    "app:build:network-tools": "bun run packages/app-sdk/bin/build.ts --dir examples/network-tools",
    "app:build:all": "bun run app:build:counter && bun run app:build:sysinfo",
    "app:build:all-wasm": "bun run app:build:counter-wasm && bun run app:build:canvas-demo-wasm && bun run app:build:wifi-marauder && bun run app:build:network-tools",
    "palanu": "bun run packages/forge-cli/bin/palanu.ts",
    "palanu:serial": "node --import tsx/esm packages/forge-cli/bin/palanu.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "tsx": "^4.22.4"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
