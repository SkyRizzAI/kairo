{
  "name": "@palanu/app-sdk",
  "version": "0.1.0",
  "description": "Palanu custom-app SDK — write device apps in TSX, build to .papp",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./jsx-runtime": "./src/jsx-runtime.ts",
    "./jsx-dev-runtime": "./src/jsx-runtime.ts",
