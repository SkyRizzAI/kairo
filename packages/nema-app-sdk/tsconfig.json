{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "jsxImportSource": "nema",
    "types": [],
    "baseUrl": ".",
    "paths": {
      "nema": ["./src/index.ts"],
      "nema/jsx-runtime": ["./src/jsx-runtime.ts"],
      "nema/jsx-dev-runtime": ["./src/jsx-runtime.ts"]
    }
  },
  "include": ["src", "templates", "bin", "scripts"]
}
