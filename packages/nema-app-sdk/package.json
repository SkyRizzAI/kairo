{
  "name": "nema",
  "version": "0.1.0",
  "description": "Kairo custom-app SDK — write device apps in TSX, build to a single .kapp",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./jsx-runtime": "./src/jsx-runtime.ts",
    "./jsx-dev-runtime": "./src/jsx-runtime.ts"
  },
  "bin": {
    "nema-build": "./bin/nema-build.ts"
  },
  "scripts": {
    "build:counter": "bun bin/nema-build.ts templates/counter",
    "verify": "bun run scripts/verify.ts"
  }
}
